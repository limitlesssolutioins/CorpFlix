generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// =====================================================
// CORE SAAS MODELS (MULTI-TENANCY)
// =====================================================

model SystemConfiguration {
  id               String   @id @default("default")
  companyName      String
  city             String
  currentYear      Int
  smlmv            Float
  transportAid     Float
  paymentFrequency String
  taxRegime        String
  updatedAt        DateTime @updatedAt
}

model Company {
  id        String   @id @default(uuid())
  name      String
  nit       String   @unique
  address   String?
  phone     String?
  email     String?
  industry  String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  audits     Audit[]
  risks      Risk[]
  documents  Document[]
  
  // HR Relations
  sites      Site[]
  positions  Position[]
  teams      Team[]
  employees  Employee[]

  // Operations Relations
  shiftPatterns ShiftPattern[]
  shifts        Shift[]
  attendance    AttendanceLog[]
  absenceTypes  AbsenceType[]
  absences      Absence[]
  payrolls      Payroll[]

  // Improvement & Support Relations
  suggestions   ImprovementSuggestion[]
  projects      ImprovementProject[]
  lessons       LessonLearned[]
  tickets       SupportTicket[]
}

model User {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// =====================================================
// AUDIT MODULE
// =====================================================

model AuditStandard {
  id          Int            @id @default(autoincrement())
  code        String         @unique // ISO9001, ISO14001, etc.
  name        String
  fullName    String
  category    String?
  color       String         @default("#3b82f6")
  description String?        @db.Text
  chapters    AuditChapter[]
}

model AuditChapter {
  id            Int                @id @default(autoincrement())
  standardId    Int
  chapterNumber String
  title         String
  description   String?            @db.Text
  createdAt     DateTime           @default(now())
  standard      AuditStandard      @relation(fields: [standardId], references: [id], onDelete: Cascade)
  requirements  AuditRequirement[]

  @@unique([standardId, chapterNumber])
}

model AuditRequirement {
  id             Int                   @id @default(autoincrement())
  chapterId      Int
  code           String
  title          String
  description    String?               @db.Text
  isAuditable    Boolean               @default(true)
  weight         Float                 @default(0)
  createdAt      DateTime              @default(now())
  chapter        AuditChapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  findings       AuditFinding[]
  auditVariables RequirementVariable[]

  @@unique([chapterId, code])
}

model RequirementVariable {
  id            Int              @id @default(autoincrement())
  requirementId Int
  text          String           @db.Text
  order         Int
  requirement   AuditRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

model Audit {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  date        DateTime @default(now())
  status      String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED
  description String?  @db.Text

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  findings AuditFinding[]

  @@index([companyId])
}

model AuditFinding {
  id            Int              @id @default(autoincrement())
  auditId       String
  requirementId Int
  type          String // CONFORMITY, NON_CONFORMITY, OPPORTUNITY, etc.
  description   String           @db.Text
  evidence      String?          @db.Text
  createdAt     DateTime         @default(now())

  audit       Audit            @relation(fields: [auditId], references: [id], onDelete: Cascade)
  requirement AuditRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
}

// =====================================================
// RISK MANAGEMENT MODULE
// =====================================================

model RiskCategory {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?  @db.Text
  color       String?
  icon        String?
  risks       Risk[]
}

model Risk {
  id           String   @id @default(uuid())
  companyId    String
  categoryId   Int
  code         String?
  title        String
  description  String?  @db.Text
  probability  Int? // 1-5
  consequence  Int? // 1-5
  residualRisk Float?
  status       String   @default("IDENTIFIED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category RiskCategory @relation(fields: [categoryId], references: [id])

  @@index([companyId])
  @@index([categoryId])
}

// =====================================================
// HUMAN RESOURCES MODULE
// =====================================================

model Site {
  id        String   @id @default(uuid())
  companyId String
  name      String
  address   String?
  createdAt DateTime @default(now())

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
}

model Position {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees        Employee[]
  positionHistories PositionHistory[]
}

model Team {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
}

model Employee {
  id                     String    @id @default(uuid())
  companyId              String
  firstName              String
  lastName               String
  identification         String
  documentType           String    @default("CC")
  documentExpeditionCity String?
  birthDate              DateTime?
  gender                 String?
  bloodType              String?
  email                  String?
  phone                  String?
  address                String?
  city                   String?

  bankName               String?
  bankAccountType        String?
  bankAccountNumber      String?

  emergencyContactName   String?
  emergencyContactPhone  String?

  contractType           String?
  contractNumber         String?
  startDate              DateTime?
  contractEndDate        DateTime?

  isIntegralSalary       Boolean   @default(false)
  salaryAmount           Float     @default(0)
  salaryScheme           String    @default("FIJO")
  payrollGroup           String?
  costCenter             String?

  contributorType        String    @default("01")
  contributorSubtype     String    @default("00")
  healthFund             String?
  healthFundPercentage   Float     @default(4)
  pensionFund            String?
  pensionFundPercentage  Float     @default(4)
  severanceFund          String?
  compensationFund       String?
  arl                    String?
  riskClass              String    @default("I")
  ciiuCode               String?

  standardStartTime      String?
  standardEndTime        String?
  standardStartTime2     String?
  standardEndTime2       String?
  workDays               String?

  defaultSiteId          String?
  defaultPositionId      String?
  teamId                 String?

  isActive               Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  company         Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultSite     Site?                     @relation(fields: [defaultSiteId], references: [id])
  defaultPosition Position?                 @relation(fields: [defaultPositionId], references: [id])
  team            Team?                     @relation(fields: [teamId], references: [id])
  documents       EmployeeDocument[]
  salaryHistory   SalaryHistory[]
  positionHistory PositionHistory[]
  disciplinary    DisciplinaryRecord[]
  evaluations     PerformanceEvaluation[]
  
  // Operations Relations
  shifts          Shift[]
  attendance      AttendanceLog[]
  absences        Absence[]
  payrollRecords  PayrollRecord[]

  @@index([companyId])
}

model EmployeeDocument {
  id         String   @id @default(uuid())
  employeeId String
  title      String
  category   String
  fileUrl    String
  expiryDate DateTime?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model SalaryHistory {
  id           String   @id @default(uuid())
  employeeId   String
  salaryAmount Float
  changeDate   DateTime @default(now())
  reason       String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model PositionHistory {
  id         String   @id @default(uuid())
  employeeId String
  positionId String
  changeDate DateTime @default(now())
  reason     String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id])
}

model DisciplinaryRecord {
  id           String   @id @default(uuid())
  employeeId   String
  incidentDate DateTime
  type         String
  description  String   @db.Text
  actionTaken  String?
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model PerformanceEvaluation {
  id             String   @id @default(uuid())
  employeeId     String
  evaluationDate DateTime
  score          Float?
  comments       String?  @db.Text
  evaluator      String?
  createdAt      DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model DocumentCategory {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?    @db.Text
  icon        String?
  documents   Document[]
}

model Document {
  id         String   @id @default(uuid())
  companyId  String
  categoryId Int
  title      String
  url        String // URL to the file
  type       String // PDF, DOCX, etc.
  version    String   @default("1.0")
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category DocumentCategory @relation(fields: [categoryId], references: [id])

  @@index([companyId])
  @@index([categoryId])
}



// =====================================================
// SHIFTS & ATTENDANCE MODULE
// =====================================================

model ShiftPattern {
  id        String   @id @default(uuid())
  companyId String
  name      String
  startTime String
  endTime   String
  days      String   // JSON string or comma separated
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shifts  Shift[]
}

model Shift {
  id           String   @id @default(uuid())
  companyId    String
  employeeId   String
  patternId    String?
  date         DateTime
  startTime    DateTime
  endTime      DateTime
  status       String   @default("SCHEDULED") // SCHEDULED, COMPLETED, MISSED
  createdAt    DateTime @default(now())

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee  Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  pattern   ShiftPattern? @relation(fields: [patternId], references: [id])
}

model AttendanceLog {
  id         String   @id @default(uuid())
  companyId  String
  employeeId String
  clockIn    DateTime
  clockOut   DateTime?
  status     String   @default("ON_TIME") // ON_TIME, LATE, EARLY_DEPARTURE
  notes      String?  @db.Text

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model AbsenceType {
  id          String   @id @default(uuid())
  companyId   String
  code        String
  name        String
  isPaid      Boolean  @default(false)
  
  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  absences Absence[]
}

model Absence {
  id         String   @id @default(uuid())
  companyId  String
  employeeId String
  typeId     String
  startDate  DateTime
  endDate    DateTime
  status     String   @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, REJECTED
  notes      String?  @db.Text

  company  Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type     AbsenceType @relation(fields: [typeId], references: [id])
}

// =====================================================
// PAYROLL MODULE
// =====================================================

model Payroll {
  id          String   @id @default(uuid())
  companyId   String
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("DRAFT") // DRAFT, PROCESSED, PAID
  createdAt   DateTime @default(now())

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  records PayrollRecord[]
}

model PayrollRecord {
  id         String   @id @default(uuid())
  payrollId  String
  employeeId String
  baseSalary Float
  additions  Float    @default(0)
  deductions Float    @default(0)
  netPay     Float
  details    String?  @db.Text // JSON string of specific items

  payroll  Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// =====================================================
// CONTINUOUS IMPROVEMENT (KAIZEN) MODULE
// =====================================================

model ImprovementSuggestion {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  description String   @db.Text
  status      String   @default("SUBMITTED") // SUBMITTED, REVIEWED, IMPLEMENTED, REJECTED
  authorId    String?  // References User or Employee depending on logic
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ImprovementProject {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  description String   @db.Text
  status      String   @default("PLANNING") // PLANNING, IN_PROGRESS, COMPLETED
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model LessonLearned {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  context     String   @db.Text
  lesson      String   @db.Text
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// =====================================================
// SUPPORT TICKETS MODULE
// =====================================================

model SupportTicket {
  id          String   @id @default(uuid())
  companyId   String
  subject     String
  description String   @db.Text
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}